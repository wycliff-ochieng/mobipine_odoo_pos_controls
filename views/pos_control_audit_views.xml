<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pos_control_audit_tree" model="ir.ui.view">
        <field name="name">pos.control.audit.list</field>
        <field name="model">pos.control.audit</field>
        <field name="arch" type="xml">
            <list default_order="create_date desc">
                <field name="create_date"/>
                <field name="action"/>
                <field name="user_id"/>
                <field name="employee_id"/>
                <field name="pos_order_id"/>
                <field name="pos_order_ref"/>
                <field name="pos_session_id"/>
                <field name="override"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_pos_control_audit_form" model="ir.ui.view">
        <field name="name">pos.control.audit.form</field>
        <field name="model">pos.control.audit</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="action"/>
                        <field name="user_id"/>
                        <field name="employee_id"/>
                        <field name="pos_order_id"/>
                        <field name="pos_order_ref"/>
                        <field name="pos_session_id"/>
                        <field name="override"/>
                        <field name="note"/>
                        <field name="create_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pos_control_audit" model="ir.actions.act_window">
        <field name="name">POS Audit Log</field>
        <field name="res_model">pos.control.audit</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_pos_control_audit"
        name="POS Audit Log"
        parent="point_of_sale.menu_point_root"
        action="action_pos_control_audit"
        groups="mobipine_odoo_pos_controls.group_pos_controls_manager"
    />
</odoo>
